# ================================================================
#2. Extract Data from a Single URL
# ================================================================
scrape_boxscore <- function(url) {
  # Read the HTML page
  page <- read_html(url)
  
  # Extract all tables
  all_tables <- html_table(page, fill = TRUE)
  
  # Return a list with named elements for clarity
  return(
    point_totals = all_tables[[1]],
    midd_boxscore = all_tables[[2]],
    midd_summary = all_tables[[3]],
    midd_random = all_tables[[4]],
    opp_boxscore = all_tables[[5]],
    opp_Summary = all_tables[[6]],
    opp_random = all_tables[[6]],
    half1_pbp = all_tables[[8]],
    half1_pbp = all_tables[[9]]
  ))
}

