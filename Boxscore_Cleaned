# ================================================================
#3. Parse Shot Data (Percentages) [Version with error handling]
# ================================================================
parse_pct_safe <- function(x) {
  # Handles "5-10" format -> 0.50
  tryCatch({
    parts <- strsplit(as.character(x), "-")
    sapply(parts, function(p) {
      if (length(p) != 2) return (NA)
      made <- suppressWarnings(as.integer(p[1]))
      att <- suppressWarnings(as.integer(p[2]))
      if (is.na(made) | is.na(att)) return (NA)
      ifelse(att == 0, NA, made / att)
    })
  }, error = function(e) {
  message("Error parsing percentages: ", e)
    return(NA)
  })
}


# ================================================================
#4. Parse Rebound Data
# ================================================================
parse_rb <- function(x) {
  # Handles "3-5" format -> ORB=3, DRB=5
  parts <- strsplit(as.character(x), "-")
  result <- sapply(parts, function(p) {
    if (length(p) != 2) return(c(NA, NA))
    c(as.integer(p[1]), as.integer(p[2]))
  })
  data.frame(ORB = result[1, ], DRB = result[2, ])
}


# ================================================================
#5. Clean the Boxscore Data
# ================================================================
clean_boxscore <- function(boxscore_df) {
  df <- boxscore_df %>%
    # Remove empty rows and header rows
    filter(!is.na(Player) & Player != "Player")
    # Parse shot percentages
    mutate(
      FG_pct = parse_pct_safe(FG),
      `3PT_pct` = parse_pct_safe(FT)
      FT_pct = parse_pct_safe(FT)
    ) %>%
    # Parse rebounds
    bind_cols(parse rb(.$`ORB-DRB`)) %>%
    # Parse starter indicator (* = started)
    mutate(
      GS = ifelse(Player == "Totals", NA,
                  ifelse(GS == "*", 1, 0))
    ) %>%
    # Convert numeric columns
    mutate(across(c(MP, FG, `3PT`, FT, REB, AST, STL, BLK, TO, PF, PTS),
                  ~supressWarnings(as.numeric(.)))) %>%
    # Remove original compound columns
    select(-c(FG, `3PT`, FT, `ORB-DRB`))
  
  return(df)
}

# Extract Game Metadata
extract_game_info <- function(url, boxscore_df)
  # Extract game ID from URL
  game_id <- sub(".*id=(\\d+).*", "\\1", url)

  # Get final score from totals row
  totals <- boxscore_df %>% filter(Player == "Totals")
  
  if (nrow(totals) > 0) {
    return(list(
      game_id = game_id,
      team_pts = totals$PTS[1],
      url = url
    ))
  }
}

# Process All Gaems (Loop Function)
process_all_games <- function(urls) {
  all_boxscores <- list()
  
  for (i in seq_along(urls)) {
    tryCatch({
      message(paste("Processing game", i, "of", length(urls)))
      
      # Scrape the page
      game_data <- scrape_boxscore(urls[i])
      
      # Clean the boxscores
      midd_clean <- clean_boxscore(game_data$midd_boxscore) %>%
        mutate(game_id = i, team = "Middlebury")
      
      opp_clean <- clean_boxscore(game_data$opp_boxscore) %>%
        mutate(game_id = i, team = "Opponent")
      
      # Combine
      all_boxscores[[i]] <- bind_rows(midd_clean, opp_clean)
      
      # Be respectful with requests
      Sys.sleep(2)
    
    }, error = function(e) {
      message(paste("Error on game", i, ":", e))
    })
  }
  
  # Combine all games into one data frame
  return(bind_rows(all_boxscores))
}

# Run it
season_boxscores <- process_all_games(game_urls)

# Save to CSV
write.csv(season_boxscores, "midd_mens_basketball_boxscores.csv", row.names = FALSE)


