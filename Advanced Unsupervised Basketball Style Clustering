# 7. More complex model #2: PyTorch gradient-based autoencoder
# ==========================================================
# This is unsupervised because it does not use a target label.
# It learns a compressed latent representation by reconstructing the input features.
# After training, we cluster the learned latent representation with GMM.

class BasketballAutoencoder(nn.Module):
    def __init__(self, input_dim, latent_dim=2, hidden_dim=16):
        super().__init__()
        self.encoder = nn.Sequential(
            nn.Linear(input_dim, hidden_dim),
            nn.ReLU(),
            nn.Linear(hidden_dim, latent_dim),
        )
        self.decoder = nn.Sequential(
            nn.Linear(latent_dim, hidden_dim),
            nn.ReLU(),
            nn.Linear(hidden_dim, input_dim),
        )

    def forward(self, x):
        z = self.encoder(x)
        reconstructed = self.decoder(z)
        return reconstructed, z


def train_autoencoder(
    X,
    latent_dim=2,
    hidden_dim=16,
    epochs=500,
    batch_size=64,
    learning_rate=1e-3,
    weight_decay=1e-4,
    patience=40,
    random_state=42,
):
    """Train an autoencoder using PyTorch gradients and return latent vectors."""
    torch.manual_seed(random_state)
    X = np.asarray(X, dtype=np.float32)

    dataset = TensorDataset(torch.tensor(X, dtype=torch.float32))
    loader = DataLoader(dataset, batch_size=min(batch_size, len(dataset)), shuffle=True)

    model = BasketballAutoencoder(input_dim=X.shape[1], latent_dim=latent_dim, hidden_dim=hidden_dim)
    optimizer = torch.optim.Adam(model.parameters(), lr=learning_rate, weight_decay=weight_decay)
    loss_fn = nn.MSELoss()

    history = []
    best_loss = np.inf
    best_state = None
    epochs_without_improvement = 0

    for epoch in range(1, epochs + 1):
        model.train()
        total_loss = 0.0
        total_rows = 0

        for (batch_x,) in loader:
            optimizer.zero_grad()
            reconstructed, _ = model(batch_x)
            loss = loss_fn(reconstructed, batch_x)
            loss.backward()
            optimizer.step()

            total_loss += loss.item() * batch_x.size(0)
            total_rows += batch_x.size(0)

        epoch_loss = total_loss / total_rows
        history.append(epoch_loss)

        if epoch_loss < best_loss - 1e-7:
            best_loss = epoch_loss
            best_state = {key: value.detach().clone() for key, value in model.state_dict().items()}
            epochs_without_improvement = 0
        else:
            epochs_without_improvement += 1

        if epochs_without_improvement >= patience:
            break

    if best_state is not None:
        model.load_state_dict(best_state)

    model.eval()
    with torch.no_grad():
        X_tensor = torch.tensor(X, dtype=torch.float32)
        reconstructed, latent = model(X_tensor)
        final_reconstruction_loss = loss_fn(reconstructed, X_tensor).item()

    return model, latent.numpy(), history, final_reconstruction_loss


print("PyTorch autoencoder class and training function are ready.")


