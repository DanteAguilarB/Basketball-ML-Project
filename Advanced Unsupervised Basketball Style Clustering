# 6. More complex model #1: Gaussian Mixture Model (GMM)
# ==========================================================
# Why this is more complex than K-Means:
# - K-Means gives hard cluster labels only.
# - GMM models each cluster as a Gaussian distribution.
# - GMM gives soft probabilities, so we can measure confidence/ambiguity.


def select_best_gmm(X, component_range=range(2, 6), covariance_type="diag", random_state=42):
    """Fit several GMMs and pick the model with the lowest BIC."""
    X = np.asarray(X, dtype=float)
    max_components = min(max(component_range), X.shape[0] - 1)
    component_range = [k for k in component_range if 1 < k <= max_components]
    if not component_range:
        raise ValueError("Not enough rows to fit a GMM with at least 2 components.")

    records = []
    fitted_models = {}

    for k in component_range:
        gmm = GaussianMixture(
            n_components=k,
            covariance_type=covariance_type,
            random_state=random_state,
            n_init=1,
            max_iter=100,
            reg_covar=1e-4,
        )
        gmm.fit(X)
        records.append({
            "n_components": k,
            "bic": gmm.bic(X),
            "aic": gmm.aic(X),
            "converged": gmm.converged_,
            "iterations": gmm.n_iter_,
        })
        fitted_models[k] = gmm

    scores = pd.DataFrame(records).sort_values("bic").reset_index(drop=True)
    best_k = int(scores.loc[0, "n_components"])
    return fitted_models[best_k], scores


gmm_model, gmm_scores = select_best_gmm(X_scaled, component_range=range(2, 6), random_state=RANDOM_STATE)

