# 3. Original custom preprocessing and K-Means classes
#    Slightly cleaned so they are safer and reusable.
# ==========================================================
class CustomStandardScaler:
    """Custom implementation of standard scaling: z = (x - mean) / std."""
    def __init__(self):
        self.mean_ = None
        self.scale_ = None

    def fit(self, X):
        X = np.asarray(X, dtype=float)
        self.mean_ = np.mean(X, axis=0)
        self.scale_ = np.std(X, axis=0)
        self.scale_[self.scale_ == 0] = 1.0
        return self

    def transform(self, X):
        if self.mean_ is None or self.scale_ is None:
            raise RuntimeError("Scaler has not been fitted yet. Call .fit() first.")
        X = np.asarray(X, dtype=float)
        return (X - self.mean_) / self.scale_

    def fit_transform(self, X):
        return self.fit(X).transform(X)

    def inverse_transform(self, X_scaled):
        if self.mean_ is None or self.scale_ is None:
            raise RuntimeError("Scaler has not been fitted yet. Call .fit() first.")
        X_scaled = np.asarray(X_scaled, dtype=float)
        return (X_scaled * self.scale_) + self.mean_


class DataPrepPipeline:
    """Simple preprocessing pipeline using the custom scaler."""
    def __init__(self):
        self.scaler = CustomStandardScaler()

    def fit_transform(self, X):
        return self.scaler.fit_transform(X)

    def transform(self, X):
        return self.scaler.transform(X)

    def inverse_transform(self, X_scaled):
        return self.scaler.inverse_transform(X_scaled)


class CustomKMeans:
    """Custom implementation of K-Means clustering."""
    def __init__(self, n_clusters=4, max_iter=300, tol=1e-6, random_state=None):
        self.n_clusters = n_clusters
        self.max_iter = max_iter
        self.tol = tol
        self.random_state = random_state
        self.centroids = None
        self.inertia_ = None
        self.n_iter_ = 0
        self.rng = np.random.default_rng(random_state)

    def _initialize_centroids(self, X):
        if X.shape[0] < self.n_clusters:
            raise ValueError("n_clusters cannot be larger than the number of rows in X.")
        indices = self.rng.choice(X.shape[0], self.n_clusters, replace=False)
        return X[indices].copy()

    def _assign_clusters(self, X, centroids):
        # Vectorized squared Euclidean distances: rows=samples, columns=clusters
        distances = ((X[:, None, :] - centroids[None, :, :]) ** 2).sum(axis=2)
        return np.argmin(distances, axis=1)

    def _update_centroids(self, X, assignments):
        new_centroids = np.zeros((self.n_clusters, X.shape[1]))
        for cluster_id in range(self.n_clusters):
            points = X[assignments == cluster_id]
            if len(points) > 0:
                new_centroids[cluster_id] = points.mean(axis=0)
            else:
                # If a cluster becomes empty, re-seed it with a random data point.
                new_centroids[cluster_id] = X[self.rng.integers(0, X.shape[0])]
        return new_centroids

    def fit(self, X):
        X = np.asarray(X, dtype=float)
        self.centroids = self._initialize_centroids(X)

        for iteration in range(1, self.max_iter + 1):
            assignments = self._assign_clusters(X, self.centroids)
            new_centroids = self._update_centroids(X, assignments)
            shift = np.linalg.norm(new_centroids - self.centroids)
            self.centroids = new_centroids
            self.n_iter_ = iteration
            if shift < self.tol:
                break

        assignments = self._assign_clusters(X, self.centroids)
        self.inertia_ = ((X - self.centroids[assignments]) ** 2).sum()
        return self

    def predict(self, X):
        if self.centroids is None:
            raise RuntimeError("KMeans model has not been fitted yet. Call .fit() first.")
        X = np.asarray(X, dtype=float)
        return self._assign_clusters(X, self.centroids)

    def fit_predict(self, X):
        return self.fit(X).predict(X)


